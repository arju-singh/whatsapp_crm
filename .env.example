# WhatsApp CRM environment configuration.
# Copy to `.env` and fill in. `.env` is gitignored and auto-loaded by src/loadenv.js.
# Anything already set in the real environment takes precedence over .env.

# --- Core -------------------------------------------------------------------
PORT=3004
# Public base URL (used for verification/reset/OAuth/webhook absolute links).
# REQUIRED in production: security-sensitive links (password reset, email verify)
# are built ONLY from this — never from the request Host header (poisoning defense).
# e.g. https://crm.example.com
PUBLIC_BASE_URL=
# If PUBLIC_BASE_URL is unset, the Host header is trusted ONLY for hosts listed
# here (comma-separated). Otherwise host-derived links are refused in production.
APP_ALLOWED_HOSTS=
NODE_ENV=development

# --- Security / auth hardening ----------------------------------------------
# Per-account login lockout: after this many failed attempts, lock for N minutes.
LOGIN_MAX_FAILS=10
LOGIN_LOCK_MINUTES=15
# Stripe webhook replay tolerance (seconds); events outside the window are rejected.
STRIPE_WEBHOOK_TOLERANCE_SEC=300

# --- Logging / observability -------------------------------------------------
# Log level: error | warn | info | debug (default info).
LOG_LEVEL=info
# Emit JSON log lines (default on in production; set 1 to force elsewhere).
LOG_JSON=

# Number of reverse-proxy hops to trust for the real client IP (makes req.ip /
# rate limiting spoof-resistant). A number of hops, or true/false. Defaults to 1
# in production, off in development. Set to your proxy depth (e.g. 1 for nginx,
# 2 behind Cloudflare+nginx). Setting this too high lets clients spoof their IP.
TRUST_PROXY=

# --- Rate limiting ----------------------------------------------------------
# Global per-IP+user budget for the whole /api surface. Tune up if power users
# hit 429s during normal dashboard use.
RATE_LIMIT_API_MAX=600
RATE_LIMIT_API_WINDOW_MS=60000

# --- First-run admin seed ---------------------------------------------------
# On a fresh database a super_admin is created. Set a password here, or leave
# blank and a strong random one is printed to the server log ONCE on first boot.
# There is NO shipped default password.
SEED_ADMIN_PHONE=919306466642
SEED_ADMIN_NAME=Arju Singh
SEED_ADMIN_PASSWORD=

# --- AI (Anthropic Claude — powers AI draft replies) ------------------------
# Server-side only. Never exposed to the browser. Can also be set in-app under
# Settings, but the env var is the recommended place in production.
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-6

# --- Lead-finder APIs (free tiers — power the "Find leads" scraper) ----------
# Optional. Each is a real REST API (no scraping, never blocked) with a free
# tier and no credit card. A source only shows in the Find-leads dropdown once
# its key is set. Can also be set in-app under Settings → Lead-finder APIs.
#   Foursquare:  https://foursquare.com/developers/  (create a project → API key)
#   HERE:        https://platform.here.com/          (free plan → REST API key)
#   TomTom:      https://developer.tomtom.com/        (register → My Apps → API key)
FOURSQUARE_API_KEY=
HERE_API_KEY=
TOMTOM_API_KEY=

# --- Inbound email webhook signing secrets ----------------------------------
# Verify Resend / Mailgun webhook signatures. Set WEBHOOK_SIGNATURE_REQUIRED=1
# in production to reject unsigned inbound webhook calls.
RESEND_WEBHOOK_SECRET=
MAILGUN_SIGNING_KEY=
WEBHOOK_SIGNATURE_REQUIRED=0

# --- Email (SMTP) — powers verification, password reset, support, campaigns --
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="WhatsApp CRM <no-reply@yourdomain.com>"

# Where contact-form and bug reports are emailed.
SUPPORT_EMAIL=connect@akshaykotish.com

# --- Stripe (subscriptions) -------------------------------------------------
# Leave blank to disable billing (endpoints return 503 billing_not_configured).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Stripe Price ID for the "pro" plan (price_...). Add more plans in billing.js.
STRIPE_PRICE_PRO=

# --- Google OAuth (Sign in with Google) -------------------------------------
# Leave blank to hide the Google button. Authorized redirect URI in Google
# Cloud console must be:  <PUBLIC_BASE_URL>/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# OAuth users are email-verified by Google; set false to require admin approval.
OAUTH_AUTO_ACTIVATE=true

# --- Search engine verification (SEO) ---------------------------------------
# Google Search Console "HTML file" method: paste the token from the filename
# Google asks you to upload (the part between "google" and ".html"). The app
# then serves /google<token>.html automatically.
GOOGLE_SITE_VERIFICATION=
# Bing Webmaster Tools "XML file" method: paste the token from BingSiteAuth.xml.
BING_SITE_VERIFICATION=

# --- Calling / Telephony ----------------------------------------------------
# Active provider for outbound calls (POST /api/calls/dial). 'log' is a dry-run
# that records the call without a carrier (default). Set to 'twilio' once the
# Twilio vars below are filled. (Can also be set per-org in Settings as
# 'call_provider'.) Other providers (plivo/exotel/vonage) are scaffolded.
CALL_PROVIDER=log
# Twilio instant-bridge: rings the agent, then dials the contact and connects
# them. Find SID + Auth Token in the Twilio Console; CALLER_ID must be a Twilio
# number (or verified caller ID) in E.164, e.g. +14155550100.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_CALLER_ID=
# The agent phone Twilio rings first (E.164). Overridable per call via the
# request's `from`, or per-org via Settings 'call_agent_number'.
TWILIO_AGENT_NUMBER=
# Optional: public URL Twilio posts call-status events to (initiated/ringing/
# answered/completed). Leave blank to skip status callbacks.
TWILIO_STATUS_CALLBACK=

# --- Queue / workers / metrics (Priority 3 infra) ---------------------------
# Job queue driver. 'memory' (default) runs jobs in-process — no Redis, the
# rollback-safe default. 'redis' uses BullMQ so N stateless API processes enqueue
# and N `npm run worker` processes consume (horizontal scaling). For redis, also
# run `npm install bullmq ioredis`.
QUEUE_DRIVER=memory
REDIS_URL=redis://127.0.0.1:6379
# On an API process that should enqueue but NOT consume (dedicated workers via
# worker.js), set this to 1. Leave unset to also process jobs in-process.
QUEUE_PRODUCER_ONLY=
# Max delivery attempts for a queued job before it is dead-lettered.
# (Outbound message send attempts are governed by WA_MAX_SEND_ATTEMPTS below.)
# Optional bearer token to protect GET /metrics (?token= or X-Metrics-Token).
METRICS_TOKEN=

# --- WhatsApp transport provider --------------------------------------------
# Which engine sends/receives WhatsApp. 'webjs' (default) = whatsapp-web.js +
# Chromium (unofficial, single-session, kept for instant rollback). 'cloud' =
# official Meta WhatsApp Business Cloud API (stateless HTTPS, no Chromium).
# 'mock' = no-network provider used by the test suite.
WA_PROVIDER=webjs
# Which org owns the single shared WhatsApp line (inbound is attributed here).
# Defaults to the default org. (Also settable via setting wa_host_org_id.)
WA_HOST_ORG_ID=
# Max delivery attempts before a message is terminally failed (both providers).
WA_MAX_SEND_ATTEMPTS=5

# --- WhatsApp Cloud API (WA_PROVIDER=cloud) ---------------------------------
# From Meta: a permanent access token, the phone-number id you send from, the
# app secret (verifies inbound webhook signatures), and a verify token you pick
# (echoed back during Meta's webhook subscription handshake). Webhook URL to give
# Meta: https://<host>/api/wa/cloud/webhook
WA_CLOUD_TOKEN=
WA_CLOUD_PHONE_NUMBER_ID=
WA_CLOUD_APP_SECRET=
WA_CLOUD_VERIFY_TOKEN=
# Optional: Graph API version and outbound rate cap (messages/sec).
WA_CLOUD_API_VERSION=v21.0
WA_CLOUD_RATE_PER_SEC=40

# --- WhatsApp Web version pin -----------------------------------------------
# whatsapp-web.js bundles a WhatsApp Web build that drifts out of sync over time;
# when it does, scanning the QR no longer links (loops back to a new QR). Pin a
# current version from github.com/wppconnect-team/wa-version. Bump this when
# WhatsApp updates again; unset to use the library's bundled version.
WA_WEB_VERSION=2.3000.1039904970-alpha
# Override the HTML source if you self-host the version cache (defaults to the
# wppconnect wa-version raw URL for WA_WEB_VERSION).
WA_WEB_VERSION_HTML=

# --- Voice AI Agent ---------------------------------------------------------
# Autonomous multilingual AI sales caller (POST /api/voice/dial). The live
# STT->LLM->TTS pipeline runs in the provider (Vapi/Retell); this app is the
# brain's tool layer + system-of-record. Every var below is also settable per-org
# in Settings (key in parentheses) — Settings (DB) overrides env.
#
# Active provider: 'log' (dry-run, records intent, no carrier — default), 'vapi',
# or 'retell'. (Settings: voice_provider)
VOICE_PROVIDER=log
# Persona + pitch (Settings: voice_agent_name / voice_company_name / voice_products).
# voice_products: newline- or JSON-array-separated "Name — what it solves" lines.
VOICE_AGENT_NAME=Ananya
VOICE_COMPANY_NAME=
VOICE_PRODUCTS=
VOICE_DEFAULT_LANGUAGE=Hinglish
# Reasoning model the agent runs on (provider inferred from id, or set explicitly).
VOICE_MODEL=claude-sonnet-4-6
VOICE_MODEL_PROVIDER=
# STT / TTS stack (provider-native ids; see Vapi/Retell docs).
VOICE_STT_PROVIDER=deepgram
VOICE_STT_MODEL=nova-2
VOICE_STT_LANGUAGE=multi
VOICE_TTS_PROVIDER=11labs
VOICE_TTS_VOICE=burt
VOICE_RECORDING=1
# lead_score >= this counts as a "qualified" lead in analytics.
VOICE_QUALIFIED_SCORE=70
# E.164 number to transfer angry/complex callers to (human handoff). Optional.
VOICE_HANDOFF_NUMBER=
# PUBLIC base URL the provider reaches our webhook at (e.g. https://crm.example.com).
# REQUIRED for real calls — the provider POSTs tool-calls + end-of-call here.
PUBLIC_BASE_URL=
# Shared secret the provider must send back (X-Vapi-Secret / x-webhook-token).
# Set this before exposing the webhook publicly. (Settings: voice_webhook_secret)
VOICE_WEBHOOK_SECRET=
# Vapi (https://vapi.ai): API key + the phoneNumberId to dial FROM.
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=
# Retell (https://retellai.com): API key, a configured agent id, and a
# Retell-registered from-number (E.164).
RETELL_API_KEY=
RETELL_AGENT_ID=
RETELL_FROM_NUMBER=
